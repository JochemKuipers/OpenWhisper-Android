<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"

    android:layout_width="match_parent"

    android:layout_height="wrap_content"

    android:orientation="vertical"

    android:paddingStart="4dp"

    android:paddingTop="4dp"

    android:paddingEnd="48dp"

    android:paddingBottom="4dp">



    <LinearLayout

        android:id="@+id/bubbleContainer"

        android:layout_width="wrap_content"

        android:layout_height="wrap_content"

        android:background="@drawable/bg_bubble_received"

        android:maxWidth="260dp"

        android:orientation="vertical"

        android:paddingHorizontal="12dp"

        android:paddingVertical="10dp">



        <LinearLayout

            android:id="@+id/attachmentContainer"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginBottom="6dp"

            android:orientation="vertical"

            android:visibility="gone">



            <ImageView

                android:id="@+id/attachmentImage"

                android:layout_width="220dp"

                android:layout_height="160dp"

                android:layout_marginBottom="4dp"

                android:contentDescription="@string/open_attachment"

                android:scaleType="centerCrop"

                android:visibility="gone" />



            <TextView

                android:id="@+id/attachmentFile"

                android:layout_width="wrap_content"

                android:layout_height="wrap_content"

                android:layout_marginBottom="4dp"

                android:textColor="?attr/colorOnSurface"

                android:textStyle="bold"

                android:visibility="gone" />



            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="end">

                <ImageButton
                    android:id="@+id/attachmentDownload"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/download_attachment"
                    android:src="@drawable/ic_download"
                    android:tint="?attr/colorPrimary" />

                <ProgressBar
                    android:id="@+id/attachmentDownloadProgress"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:indeterminate="true"
                    android:indeterminateTint="?attr/colorPrimary"
                    android:visibility="gone" />
            </FrameLayout>

        </LinearLayout>



        <TextView

            android:id="@+id/bubble"

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:textAppearance="?attr/textAppearanceBodyMedium"

            android:textColor="?attr/colorOnSurface" />

    </LinearLayout>



    <TextView

        android:id="@+id/timestamp"

        android:layout_width="wrap_content"

        android:layout_height="wrap_content"

        android:layout_marginStart="4dp"

        android:layout_marginTop="4dp"

        android:textAppearance="?attr/textAppearanceLabelSmall"

        android:textColor="@color/ow_text_secondary"

        android:textSize="11sp" />

</LinearLayout>

