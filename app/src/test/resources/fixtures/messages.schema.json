{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["messages"],
  "properties": {
    "$schema": { "type": "string" },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url", "sender", "content", "created_at"],
        "properties": {
          "url": { "type": "string" },
          "sender": {
            "type": "object",
            "required": ["username"],
            "properties": {
              "username": { "type": "string" }
            }
          },
          "content": { "type": "string" },
          "attachment_url": { "type": ["string", "null"] },
          "created_at": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
